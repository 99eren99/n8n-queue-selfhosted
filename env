 # General
N8N_VERSION=2.19.3
GENERIC_TIMEZONE=Europe/Istanbul
N8N_ENCRYPTION_KEY=your-very-long-secret-key-here

    # PostgreSQL
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=n8n

    # Redis
REDIS_PASSWORD=change-this-redis-password

    # n8n
N8N_HOST=0.0.0.0
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://your_host_ip:80
WEBHOOK_URL=http://your_host_ip:80

N8N_PROXY_HOPS=1
N8N_TRUST_PROXY=true
N8N_ALLOW_UNSAFE_WEBHOOK_URL=true

    # Queue Mode
EXECUTIONS_MODE=queue
QUEUE_BULL_REDIS_HOST=redis
QUEUE_BULL_REDIS_PORT=6379
QUEUE_BULL_REDIS_PASSWORD=${REDIS_PASSWORD}

    # Database
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=${POSTGRES_DB}
DB_POSTGRESDB_USER=${POSTGRES_USER}
DB_POSTGRESDB_PASSWORD=${POSTGRES_PASSWORD}

    # Task Runner
N8N_RUNNERS_MODE=external
N8N_RUNNERS_AUTH_TOKEN=your-secret-token-for-runners
OFFLOAD_MANUAL_EXECUTIONS_TO_WORKERS=true